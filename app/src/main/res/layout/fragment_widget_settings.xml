<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/settings_background"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingHorizontal="16dp"
        android:paddingTop="20dp"
        android:paddingBottom="32dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="6dp"
            android:text="Widget innstillinger"
            android:textColor="@color/settings_text_primary"
            android:textSize="22sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="20dp"
            android:text="Velg region eller bruk din posisjon for å vise skredvarsel i widgeten."
            android:textColor="@color/settings_text_secondary"
            android:textSize="14sp" />

        <!-- Current selection card -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            app:cardBackgroundColor="@color/settings_surface"
            app:cardCornerRadius="14dp"
            app:cardElevation="0dp"
            app:strokeColor="@color/settings_divider"
            app:strokeWidth="1dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="4dp"
                    android:text="Valgt region"
                    android:textColor="@color/settings_text_tertiary"
                    android:textSize="12sp"
                    android:textAllCaps="true"
                    android:letterSpacing="0.06" />

                <TextView
                    android:id="@+id/current_region_text"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Tromsø"
                    android:textColor="@color/settings_accent"
                    android:textSize="20sp"
                    android:textStyle="bold" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Use my location action -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/use_location_button"
            style="@style/Widget.MaterialComponents.Button"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:layout_marginBottom="24dp"
            android:text="Bruk min posisjon"
            android:textAllCaps="false"
            android:textSize="15sp"
            android:textStyle="bold"
            app:backgroundTint="@color/settings_accent"
            app:cornerRadius="14dp"
            app:icon="@android:drawable/ic_menu_mylocation"
            app:iconGravity="textStart"
            app:iconPadding="10dp"
            app:iconTint="@color/settings_text_primary" />

        <!-- Section header -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="8dp"
            android:text="ELLER VELG FRA LISTEN"
            android:textColor="@color/settings_text_tertiary"
            android:textSize="11sp"
            android:letterSpacing="0.08" />

        <!-- Search bar -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="8dp"
            app:cardBackgroundColor="@color/settings_surface"
            app:cardCornerRadius="14dp"
            app:cardElevation="0dp"
            app:strokeColor="@color/settings_divider"
            app:strokeWidth="1dp">

            <SearchView
                android:id="@+id/region_search"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@android:color/transparent"
                android:iconifiedByDefault="false"
                android:queryHint="Søk regioner…"
                android:theme="@style/ThemeOverlay.AppCompat.Dark" />
        </com.google.android.material.card.MaterialCardView>

        <!-- Region list (dynamic-height ListView; height computed in fragment) -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardBackgroundColor="@color/settings_surface"
            app:cardCornerRadius="14dp"
            app:cardElevation="0dp"
            app:strokeColor="@color/settings_divider"
            app:strokeWidth="1dp">

            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content">

                <ListView
                    android:id="@+id/region_list"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:divider="@color/settings_divider"
                    android:dividerHeight="1dp"
                    android:nestedScrollingEnabled="true"
                    android:scrollbars="vertical" />
            </FrameLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Hidden no-op kept for binding compatibility; previously a duplicate "Velg region"
             button that just scrolled focus. Removed visually. -->
        <Button
            android:id="@+id/select_region_button"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:visibility="gone" />
    </LinearLayout>
</androidx.core.widget.NestedScrollView>
